---
import { useTranslations } from "../i18n/utils";
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="inicio" class="bg-blue-600 text-white py-28">
  <div class="max-w-7xl mx-auto px-6 text-center">
    <h1 class="text-5xl font-bold mb-6">
      {t("hero.title")}
    </h1>

    <p class="text-lg mb-8 max-w-2xl mx-auto">
      {t("hero.subtitle")}
    </p>

    <div class="flex justify-center gap-4">
      <a
        href="#contacto"
        class="bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-200"
      >
        {t("hero.button")}
      </a>

      <a
        href="#servicios"
        class="border border-white px-6 py-3 rounded-lg hover:bg-blue-500"
      >
        {t("hero.view_services")  }
      </a>
    </div>
  </div>
</section>
