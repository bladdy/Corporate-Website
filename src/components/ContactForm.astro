<section id="contacto" class="py-24">
  <div class="max-w-3xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-center mb-10">
      Solicita una Cotización
    </h2>

    <form class="bg-white shadow-lg rounded-xl p-8 space-y-6">
      <div>
        <label class="block font-medium mb-1"> Nombre </label>

        <input type="text" class="w-full border rounded-lg px-4 py-2" />
      </div>

      <div>
        <label class="block font-medium mb-1"> Correo </label>

        <input type="email" class="w-full border rounded-lg px-4 py-2" />
      </div>

      <div>
        <label class="block font-medium mb-1"> Mensaje </label>

        <textarea rows="4" class="w-full border rounded-lg px-4 py-2"
        ></textarea>
      </div>

      <button
        class="w-full bg-blue-600 text-white py-3 rounded-lg hover:bg-blue-700"
      >
        Enviar
      </button>
    </form>
  </div>
</section>
